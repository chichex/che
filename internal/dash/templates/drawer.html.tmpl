{{/* drawer.html.tmpl — partial swappeado por hx-get="/drawer/{id}".

     Recibe drawerData ({Entity, NWO}). Adapta contenido según Kind:
       - Fused (Kind=1): tabs "PR | Issue" — el tab PR tiene todo el contenido
         operacional (meta, actions, logs); el tab Issue muestra el body del
         issue original como contexto histórico.
       - Issue-only: vista única con el contenido actual + body al pie si lo hay.

     Wrapper externo: .modal-backdrop > .modal (overlay sobre el board, no
     sidebar). Las clases internas mantienen prefix drawer-* para minimizar
     churn — solo cambia el envoltorio. data-entity y data-tab viven en .modal
     para que dash.js pueda togglear tabs delegando el click. */}}
{{/* $key es la clave canónica del routing: IssueNumber para KindIssue/Fused,
     PRNumber para KindPR (adopt sin issue linkeado). Se usa en hx-post,
     data-entity y SSE stream. Ver Entity.EntityKey. */}}
{{define "pipeline-step-actions"}}
  {{if .PipelineSteps}}
    {{$key := .IssueNumber}}{{if eq .Kind 2}}{{$key = .PRNumber}}{{end}}
    <dl class="drawer-meta pipeline-meta">
      <dt>pipeline</dt><dd>steps del pipeline activo; el step actual queda habilitado para reanudar con <code>che run --auto --from</code></dd>
      {{range .PipelineSteps}}
        <dt>{{if .Current}}actual{{else}}step{{end}}</dt>
        <dd><code>{{.Name}}</code>{{if .Applying}} · applying{{end}}{{if .Agents}} · agents: {{joinStrings .Agents ", "}}{{end}}{{if .Aggregator}} · {{.Aggregator}}{{end}}{{if .Comment}} · {{.Comment}}{{end}}</dd>
      {{end}}
    </dl>
    <div class="drawer-actions pipeline-actions">
      {{range .PipelineSteps}}
        {{$btn := flowBtnState .Flow $.RunningFlow $.Gates (printf "run --from %s" .Name)}}
        <button class="btn {{if .Current}}primary{{else}}ghost{{end}}"
                hx-post="/action/run/{{.Name}}/{{$key}}"
                hx-target="#modal-slot"
                hx-swap="innerHTML"
                {{if $btn.Disabled}}disabled{{end}} title="{{$btn.Title}}">{{.Name}}</button>
      {{end}}
      <span class="needs-human-hint" style="color:var(--muted); font-size: 11px; padding: 6px 0;">manual: elegí agentes desde <code>che run --manual --from &lt;step&gt;</code></span>
    </div>
    {{if not .RunningFlow}}
      <div class="drawer-blocked-reasons">
        {{range .PipelineSteps}}{{if not .Gate.Available}}<div class="reason"><span class="flow">{{.Name}}</span> ⛔ {{.Gate.Reason}}</div>{{end}}{{end}}
      </div>
    {{end}}
  {{end}}
{{end}}
{{$key := .IssueNumber}}{{if eq .Kind 2}}{{$key = .PRNumber}}{{end}}
<div class="modal-backdrop">
<div class="modal" data-entity="{{$key}}" data-tab="pr">

  {{if eq .Kind 2}}
    {{/* ============= KindPR (PR sin issue linkeado) =============
         Sin tabs — no hay issue que mostrar. Ref solo al PR.
         Acciones varían según Status:
           - "adopt"      → solo validate (puerta de entrada al state machine).
           - "validated"  → iterate (si verdict=changes-requested) + validate + close.
           - "executed"   → idem (raro vía adopt; cubre PRs que reentran).
         explore/execute siguen excluidos: son issue-first. */}}
    <div class="drawer-hdr">
      <div class="drawer-hdr-top">
        <div class="entity-row">
          <a href="https://github.com/{{.NWO}}/pull/{{.PRNumber}}" target="_blank" rel="noopener"><b>!{{.PRNumber}}</b></a>
          {{- if .Branch}} · {{.Branch}}{{end -}}
          {{- if .SHA}} · {{.SHA}}{{end -}}
        </div>
        <button class="drawer-close"
                hx-get="/drawer/close"
                hx-target="#modal-slot"
                hx-swap="innerHTML"
                title="cerrar (Esc)">×</button>
      </div>
      <h3>{{.PRTitle}}</h3>
      <div class="sub">{{.Column}} · PR sin issue trackeado</div>
      <div class="drawer-chips">
        {{if eq .Status "adopt"}}<span class="chip chip-orange" title="PR no linkeado a ningún issue con labels che:*">adopt</span>{{end}}
        {{if checksLabel .Entity }}<span class="chip {{checksChipClass .Entity}}">{{checksLabel .Entity}}</span>{{end}}
        {{if .PRVerdict}}<span class="chip {{verdictChipClass .PRVerdict}}">validated:{{.PRVerdict}}</span>{{end}}
        {{if .Locked}}<span class="chip chip-lock">🔒 locked</span>{{end}}
        {{if .RunningFlow}}<span class="chip chip-magenta">⟳ {{displayFlow .RunningFlow}} {{.RunIter}}/{{.RunMax}}</span>{{end}}
        {{if and .RunningFlow .Auto}}<span class="chip chip-magenta" title="disparado por el auto-loop engine">auto</span>{{end}}
        {{if .StateStepOrphan}}<span class="chip chip-red">step orphan: <code>{{.StateStep}}</code></span>{{end}}
        {{if .CapReached}}<span class="chip chip-cap" title="auto-loop detenido: alcanzó el cap de {{.RunMax}} rondas. Re-corré che manualmente para seguir.">⛔ cap {{.RunMax}}/{{.RunMax}}</span>{{end}}
      </div>
    </div>

    {{template "pipeline-step-actions" .}}

    <div class="drawer-actions">
      {{/* Botones por Status (espejo del bloque fused, líneas 161+):
             - adopt     → solo validate (puerta de entrada).
             - resto     → iterate + validate + close (cuando aplican vía gates).
           validate resuelve via stateref con fallback al PR cuando no hay
           issue con che:* (ver internal/flow/stateref). $key=PRNumber para
           KindPR — el server enruta por EntityKey y resolveTargetRef. */}}
      {{$showIterate := false}}{{$showClose := false}}
      {{if eq .Status "adopt"}}
        {{$bv := flowBtnState "validate" .RunningFlow .Gates (printf "validate !%d" .PRNumber)}}
        <button class="btn warn"
                hx-post="/action/validate/{{$key}}"
                hx-target="#modal-slot"
                hx-swap="innerHTML"
                {{if $bv.Disabled}}disabled{{end}} title="{{$bv.Title}}">validate</button>
      {{else}}
        {{$showIterate = true}}
        {{$bi := flowBtnState "iterate" .RunningFlow .Gates (printf "iterate !%d" .PRNumber)}}
        <button class="btn primary"
                hx-post="/action/iterate/{{$key}}"
                hx-target="#modal-slot"
                hx-swap="innerHTML"
                {{if $bi.Disabled}}disabled{{end}} title="{{$bi.Title}}">iterate</button>
        {{$bv := flowBtnState "validate" .RunningFlow .Gates (printf "validate !%d" .PRNumber)}}
        <button class="btn warn"
                hx-post="/action/validate/{{$key}}"
                hx-target="#modal-slot"
                hx-swap="innerHTML"
                {{if $bv.Disabled}}disabled{{end}} title="{{$bv.Title}}">validate</button>
        {{if or (eq .Status "executed") (eq .Status "validated")}}
        {{$showClose = true}}
        {{$bc := flowBtnState "close" .RunningFlow .Gates (printf "close !%d (mergea y cierra el PR)" .PRNumber)}}
        <button class="btn danger"
                hx-post="/action/close/{{$key}}"
                hx-target="#modal-slot"
                hx-swap="innerHTML"
                {{if $bc.Disabled}}disabled{{end}} title="{{$bc.Title}}">close</button>
        {{end}}
      {{end}}
      <a class="btn ghost" style="margin-left:auto"
         href="https://github.com/{{.NWO}}/pull/{{.PRNumber}}"
         target="_blank" rel="noopener">ver en GH</a>
    </div>
    {{/* Reasons inline: motivos de gate bloqueado (no de RunningFlow).
         Re-resolvemos via gateOf — los $b* de arriba viven dentro del if. */}}
    {{$gv := gateOf "validate" .Gates}}
    {{$gi := gateOf "iterate" .Gates}}
    {{$gc := gateOf "close" .Gates}}
    {{if and (not .RunningFlow) (or (not $gv.Available) (and $showIterate (not $gi.Available)) (and $showClose (not $gc.Available)))}}
    <div class="drawer-blocked-reasons">
      {{if not $gv.Available}}<div class="reason"><span class="flow">validate</span> ⛔ {{$gv.Reason}}</div>{{end}}
      {{if and $showIterate (not $gi.Available)}}<div class="reason"><span class="flow">iterate</span> ⛔ {{$gi.Reason}}</div>{{end}}
      {{if and $showClose (not $gc.Available)}}<div class="reason"><span class="flow">close</span> ⛔ {{$gc.Reason}}</div>{{end}}
    </div>
    {{end}}

    <div class="drawer-logs">
      <div class="drawer-logs-hdr">
        <span><b>stream</b>{{if .RunningFlow}} · claude {{displayFlow .RunningFlow}} · run {{.RunIter}}{{end}}</span>
        <div class="ctl">
          <span class="on">● auto-scroll</span>
          <span>pause</span>
          <span>clear</span>
        </div>
      </div>
      <div class="drawer-logs-body" data-entity="{{$key}}">
        <div class="live-log"></div>
        <div class="live-empty" style="color:var(--muted)">sin logs todavía — dispará validate o close para ver el stream en vivo.</div>
        {{if .RunningFlow}}<div class="live-cursor"><span class="cursor">&nbsp;</span></div>{{end}}
      </div>
    </div>

  {{else if eq .Kind 1}}
    {{/* ============= FUSED: tabs PR | Issue ============= */}}
    <div class="drawer-tabs">
      <button type="button" class="tab tab-pr" data-tab="pr">PR !{{.PRNumber}}</button>
      <button type="button" class="tab tab-issue" data-tab="issue">Issue #{{.IssueNumber}}</button>
    </div>

    <div class="pane pane-pr">
      <div class="drawer-hdr">
        <div class="drawer-hdr-top">
          <div class="entity-row">
            from <a href="https://github.com/{{.NWO}}/issues/{{.IssueNumber}}" target="_blank" rel="noopener"><b>#{{.IssueNumber}}</b></a> · <a href="https://github.com/{{.NWO}}/pull/{{.PRNumber}}" target="_blank" rel="noopener"><b>!{{.PRNumber}}</b></a>
            {{- if .Branch}} · {{.Branch}}{{end -}}
            {{- if .SHA}} · {{.SHA}}{{end -}}
          </div>
          <button class="drawer-close"
                  hx-get="/drawer/close"
                  hx-target="#modal-slot"
                  hx-swap="innerHTML"
                  title="cerrar (Esc)">×</button>
        </div>
        <h3>{{if .PRTitle}}{{.PRTitle}}{{else}}{{.IssueTitle}}{{end}}</h3>
        <div class="sub">
          {{.Column}}
          {{- if .LoopSpec}} · loop {{.LoopSpec}}{{end -}}
        </div>
        <div class="drawer-chips">
          {{if eq .Status "adopt"}}<span class="chip chip-orange" title="issue linkeado no tiene labels che:* — adoptable desde acá">adopt</span>{{else}}<span class="chip">ct:plan</span>{{end}}
          {{if .Type}}<span class="chip">type:{{.Type}}</span>{{end}}
          {{if .Size}}<span class="chip">size:{{.Size}}</span>{{end}}
          {{if .PRVerdict}}<span class="chip {{verdictChipClass .PRVerdict}}">validated:{{.PRVerdict}}</span>{{end}}
          {{/* Pasamos .Entity explícito porque las funcs del template (checksLabel,
               checksChipClass, hasChecks) reciben dash.Entity y el dato de acá
               es drawerData (wrapper con NWO). Los campos sueltos sí se promueven
               gracias al embedding. */}}
          {{if checksLabel .Entity }}<span class="chip {{checksChipClass .Entity}}">{{checksLabel .Entity}}</span>{{end}}
          {{if .Locked}}<span class="chip chip-lock">🔒 locked</span>{{end}}
          {{if .RunningFlow}}<span class="chip chip-magenta">⟳ {{displayFlow .RunningFlow}} {{.RunIter}}/{{.RunMax}}</span>{{end}}
          {{if and .RunningFlow .Auto}}<span class="chip chip-magenta" title="disparado por el auto-loop engine">auto</span>{{end}}
          {{if .StateStepOrphan}}<span class="chip chip-red">step orphan: <code>{{.StateStep}}</code></span>{{end}}
          {{if .CapReached}}<span class="chip chip-cap" title="auto-loop detenido: alcanzó el cap de {{.RunMax}} rondas. Re-corré che manualmente para seguir.">⛔ cap {{.RunMax}}/{{.RunMax}}</span>{{end}}
        </div>
      </div>

      <dl class="drawer-meta">
        {{if .LoopSpec}}<dt>loop</dt><dd class="loop-line">{{.LoopSpec}}</dd>{{end}}
        {{if .LastAction}}<dt>última</dt><dd>{{.LastAction}}</dd>{{end}}
        {{if .NextAction}}<dt>next</dt><dd>{{.NextAction}}</dd>{{end}}
        {{if hasChecks .Entity}}
          <dt>checks (CI)</dt>
          <dd>
            {{if .ChecksOK}}<span style="color:var(--green)">{{.ChecksOK}} ok</span>{{end}}
            {{if .ChecksPending}}{{if .ChecksOK}} · {{end}}<span style="color:var(--orange)">{{.ChecksPending}} pending</span>{{end}}
            {{if .ChecksFail}}{{if or .ChecksOK .ChecksPending}} · {{end}}<span style="color:var(--red)">{{.ChecksFail}} fail</span>{{end}}
          </dd>
        {{end}}
        {{if .PRVerdict}}<dt>verdict</dt><dd style="color:{{verdictColor .PRVerdict}}">validated:{{.PRVerdict}}</dd>{{end}}
      </dl>

      {{template "pipeline-step-actions" .}}

      <div class="drawer-actions">
        {{/* Botones fire-and-forget: hx-post lanza el subcomando y swapea
             el modal con el drawer refreshado (ya muestra ⟳ y botones
             disabled). Si RunningFlow != "", toda la row entra disabled
             para evitar doble dispatch mientras corre el flow.

             El id del URL es IssueNumber (clave canónica del modal, del
             LogStore y del overlay). El server mapea a PRNumber antes de
             invocar al subcomando para los flows que lo requieren — ver
             resolveTargetRef en server.go.

             flowBtnState consulta .Gates para resolver disabled+title con
             el motivo concreto (locked, status no aplica, body sin plan
             consolidado, verdict pendiente, etc). */}}
        {{$showIterate := false}}{{$showClose := false}}
        {{if eq .Status "adopt"}}
          {{/* Fused en adopt: el issue linkeado no tiene che:*, así que el
               lifecycle che no arrancó. Set fijo de adopt para fused →
               solo validate (puerta de entrada). close vive en el state
               machine post-validate. */}}
          {{$bv := flowBtnState "validate" .RunningFlow .Gates (printf "validate !%d" .PRNumber)}}
          <button class="btn warn"
                  hx-post="/action/validate/{{.IssueNumber}}"
                  hx-target="#modal-slot"
                  hx-swap="innerHTML"
                  {{if $bv.Disabled}}disabled{{end}} title="{{$bv.Title}}">validate</button>
        {{else}}
          {{$showIterate = true}}
          {{$bi := flowBtnState "iterate" .RunningFlow .Gates (printf "iterate !%d" .PRNumber)}}
          <button class="btn primary"
                  hx-post="/action/iterate/{{.IssueNumber}}"
                  hx-target="#modal-slot"
                  hx-swap="innerHTML"
                  {{if $bi.Disabled}}disabled{{end}} title="{{$bi.Title}}">iterate</button>
          {{$bv := flowBtnState "validate" .RunningFlow .Gates (printf "validate !%d" .PRNumber)}}
          <button class="btn warn"
                  hx-post="/action/validate/{{.IssueNumber}}"
                  hx-target="#modal-slot"
                  hx-swap="innerHTML"
                  {{if $bv.Disabled}}disabled{{end}} title="{{$bv.Title}}">validate</button>
          {{/* close visible en che:executed y che:validated (los estados que
               acepta `che close <pr>`). El comando warnea (no rechaza) si
               el verdict no es approve — el click ES la decisión humana
               per memoria feedback_close_no_gate. */}}
          {{if or (eq .Status "executed") (eq .Status "validated")}}
          {{$showClose = true}}
          {{$bc := flowBtnState "close" .RunningFlow .Gates (printf "close !%d (mergea y cierra el issue)" .PRNumber)}}
          <button class="btn danger"
                  hx-post="/action/close/{{.IssueNumber}}"
                  hx-target="#modal-slot"
                  hx-swap="innerHTML"
                  {{if $bc.Disabled}}disabled{{end}} title="{{$bc.Title}}">close</button>
          {{end}}
        {{end}}
        <a class="btn ghost" style="margin-left:auto"
           href="https://github.com/{{.NWO}}/pull/{{.PRNumber}}"
           target="_blank" rel="noopener">ver en GH</a>
      </div>
      {{/* Reasons inline para fused. Re-resolvemos los gates acá (sin RunningFlow
           prefix porque ya no nos interesa "flow X en curso" — eso lo dice el chip ⟳;
           solo queremos motivos de gate). */}}
      {{$gv := gateOf "validate" .Gates}}
      {{$gi := gateOf "iterate" .Gates}}
      {{$gc := gateOf "close" .Gates}}
      {{if and (not .RunningFlow) (or (not $gv.Available) (and $showIterate (not $gi.Available)) (and $showClose (not $gc.Available)))}}
      <div class="drawer-blocked-reasons">
        {{if not $gv.Available}}<div class="reason"><span class="flow">validate</span> ⛔ {{$gv.Reason}}</div>{{end}}
        {{if and $showIterate (not $gi.Available)}}<div class="reason"><span class="flow">iterate</span> ⛔ {{$gi.Reason}}</div>{{end}}
        {{if and $showClose (not $gc.Available)}}<div class="reason"><span class="flow">close</span> ⛔ {{$gc.Reason}}</div>{{end}}
      </div>
      {{end}}

      <div class="drawer-logs">
        <div class="drawer-logs-hdr">
          <span><b>stream</b>{{if .RunningFlow}} · claude {{displayFlow .RunningFlow}} · run {{.RunIter}}{{end}}</span>
          <div class="ctl">
            <span class="on">● auto-scroll</span>
            <span>pause</span>
            <span>clear</span>
          </div>
        </div>
        {{/* Cuerpo del stream: logs históricos del snapshot (si los hay) +
             mount point `.live-log` donde dash.js vuelca los eventos SSE
             en tiempo real. El placeholder `.live-empty` desaparece apenas
             llega la primera línea (lo esconde el JS). */}}
        <div class="drawer-logs-body" data-entity="{{$key}}">
          {{if .LogRuns}}
            {{range .LogRuns}}
              <div class="run-sep">{{.Label}}</div>
              {{range .Entries}}
                <div>
                  <span class="t">{{.Time}}</span>
                  {{- if .Class}} <span class="{{.Class}}">{{.Text}}</span>{{else}} {{.Text}}{{end -}}
                </div>
              {{end}}
            {{end}}
          {{end}}
          <div class="live-log"></div>
          <div class="live-empty" style="color:var(--muted)">sin logs todavía — dispará un flow desde los botones de arriba para ver el stream en vivo.</div>
          {{if .RunningFlow}}<div class="live-cursor"><span class="cursor">&nbsp;</span></div>{{end}}
        </div>
      </div>
    </div>

    <div class="pane pane-issue">
      {{/* Tab Issue: header con ref del issue + body. Sin acciones (las
           acciones del issue viven en el PR ahora que están fused). El
           body se renderiza como markdown (GFM) — renderMarkdown escapa
           el raw HTML del input, así que es seguro insertar como HTML. */}}
      <div class="drawer-hdr">
        <div class="drawer-hdr-top">
          <div class="entity-row">
            <a href="https://github.com/{{.NWO}}/issues/{{.IssueNumber}}" target="_blank" rel="noopener"><b>#{{.IssueNumber}}</b></a>
          </div>
          <button class="drawer-close"
                  hx-get="/drawer/close"
                  hx-target="#modal-slot"
                  hx-swap="innerHTML"
                  title="cerrar (Esc)">×</button>
        </div>
        <h3>{{.IssueTitle}}</h3>
      </div>
      <div class="drawer-issue-body">
        {{if .IssueBody}}
          <div class="md">{{renderMarkdown .IssueBody}}</div>
        {{else}}
          <div style="color:var(--muted); padding: 12px 16px;">issue sin descripción</div>
        {{end}}
      </div>
    </div>

  {{else}}
    {{/* ============= ISSUE-ONLY: vista única ============= */}}
    <div class="drawer-hdr">
      <div class="drawer-hdr-top">
        <div class="entity-row">
          <a href="https://github.com/{{.NWO}}/issues/{{.IssueNumber}}" target="_blank" rel="noopener"><b>#{{.IssueNumber}}</b></a>
          {{- if .Branch}} · {{.Branch}}{{end -}}
          {{- if .SHA}} · {{.SHA}}{{end -}}
        </div>
        <button class="drawer-close"
                hx-get="/drawer/close"
                hx-target="#modal-slot"
                hx-swap="innerHTML"
                title="cerrar (Esc)">×</button>
      </div>
      <h3>{{.IssueTitle}}</h3>
      <div class="sub">
        {{.Column}}
        {{- if .LoopSpec}} · loop {{.LoopSpec}}{{end -}}
      </div>
      <div class="drawer-chips">
        <span class="chip">ct:plan</span>
        {{if .Type}}<span class="chip">type:{{.Type}}</span>{{end}}
        {{if .Size}}<span class="chip">size:{{.Size}}</span>{{end}}
        {{if .PlanVerdict}}<span class="chip {{verdictChipClass .PlanVerdict}}">plan-validated:{{.PlanVerdict}}</span>{{end}}
        {{if .Locked}}<span class="chip chip-lock">🔒 locked</span>{{end}}
        {{if .RunningFlow}}<span class="chip chip-magenta">⟳ {{displayFlow .RunningFlow}} {{.RunIter}}/{{.RunMax}}</span>{{end}}
        {{if and .RunningFlow .Auto}}<span class="chip chip-magenta" title="disparado por el auto-loop engine">auto</span>{{end}}
        {{if .StateStepOrphan}}<span class="chip chip-red">step orphan: <code>{{.StateStep}}</code></span>{{end}}
        {{if .CapReached}}<span class="chip chip-cap" title="auto-loop detenido: alcanzó el cap de {{.RunMax}} rondas. Re-corré che manualmente para seguir.">⛔ cap {{.RunMax}}/{{.RunMax}}</span>{{end}}
      </div>
    </div>

    <dl class="drawer-meta">
      {{if .LoopSpec}}<dt>loop</dt><dd class="loop-line">{{.LoopSpec}}</dd>{{end}}
      {{if .LastAction}}<dt>última</dt><dd>{{.LastAction}}</dd>{{end}}
      {{if .NextAction}}<dt>next</dt><dd>{{.NextAction}}</dd>{{end}}
      {{if .PlanVerdict}}<dt>verdict</dt><dd style="color:{{verdictColor .PlanVerdict}}">plan-validated:{{.PlanVerdict}}</dd>{{end}}
    </dl>

    {{if .MigrateHint}}
      <div class="drawer-blocked-reasons">
        <div class="reason"><span class="flow">pipeline</span> ejecutá <code>che pipeline migrate-labels</code> para convertir labels legacy al pipeline custom activo.</div>
      </div>
    {{end}}

    {{template "pipeline-step-actions" .}}

    <div class="drawer-actions">
      {{/* Issue-only: botones varían por Status. flowBtnState consulta gates
           para mostrar disabled+title con el motivo concreto (body sin plan
           consolidado, locked, status no aplica, etc). RunningFlow tiene
           prioridad sobre gate (transient > razón estructural). "ver en GH"
           es un <a> — link directo, sin backend ni hx-post.

           Trackeamos qué botones renderizamos en $shown<flow> para luego
           rendear los reasons solo para los visibles (no queremos mostrar
           "iterate ⛔ ..." si el botón iterate ni siquiera se renderiza
           para este Status). */}}
      {{$shownExplore := false}}{{$shownExecute := false}}{{$shownValidate := false}}{{$shownIterate := false}}
      {{if eq .Status "adopt"}}
        {{/* Issue-only en adopt: puerta de entrada al state machine. Set
             fijo = explore + execute + validate. Edge case actual (issues
             sin che:* se skipean en combineEntities) — el set queda como
             defensa para cuando un issue caiga en adopt en el futuro. */}}
        {{$shownExplore = true}}
        {{$be := flowBtnState "explore" .RunningFlow .Gates (printf "explore #%d" .IssueNumber)}}
        <button class="btn primary"
                hx-post="/action/explore/{{.IssueNumber}}"
                hx-target="#modal-slot"
                hx-swap="innerHTML"
                {{if $be.Disabled}}disabled{{end}} title="{{$be.Title}}">explore</button>
        {{$shownExecute = true}}
        {{$bx := flowBtnState "execute" .RunningFlow .Gates (printf "execute #%d" .IssueNumber)}}
        <button class="btn primary"
                hx-post="/action/execute/{{.IssueNumber}}"
                hx-target="#modal-slot"
                hx-swap="innerHTML"
                {{if $bx.Disabled}}disabled{{end}} title="{{$bx.Title}}">execute</button>
        {{$shownValidate = true}}
        {{$bv := flowBtnState "validate" .RunningFlow .Gates (printf "validate #%d" .IssueNumber)}}
        <button class="btn warn"
                hx-post="/action/validate/{{.IssueNumber}}"
                hx-target="#modal-slot"
                hx-swap="innerHTML"
                {{if $bv.Disabled}}disabled{{end}} title="{{$bv.Title}}">validate</button>
      {{else if eq .Status "idea"}}
        {{$shownExplore = true}}
        {{$be := flowBtnState "explore" .RunningFlow .Gates (printf "explore #%d" .IssueNumber)}}
        <button class="btn primary"
                hx-post="/action/explore/{{.IssueNumber}}"
                hx-target="#modal-slot"
                hx-swap="innerHTML"
                {{if $be.Disabled}}disabled{{end}} title="{{$be.Title}}">explore</button>
      {{else if eq .Status "plan"}}
        {{$shownExecute = true}}
        {{$bx := flowBtnState "execute" .RunningFlow .Gates (printf "execute #%d" .IssueNumber)}}
        <button class="btn primary"
                hx-post="/action/execute/{{.IssueNumber}}"
                hx-target="#modal-slot"
                hx-swap="innerHTML"
                {{if $bx.Disabled}}disabled{{end}} title="{{$bx.Title}}">execute</button>
        {{$shownValidate = true}}
        {{$bv := flowBtnState "validate" .RunningFlow .Gates (printf "validate #%d" .IssueNumber)}}
        <button class="btn warn"
                hx-post="/action/validate/{{.IssueNumber}}"
                hx-target="#modal-slot"
                hx-swap="innerHTML"
                {{if $bv.Disabled}}disabled{{end}} title="{{$bv.Title}}">validate</button>
      {{else if eq .Status "validated"}}
        {{/* che:validated issue-only (plan validado). El siguiente paso depende
             del verdict del plan:
               - changes-requested → iterate (el validador pidió cambios).
               - needs-human       → ningún botón; el humano resuelve a mano
                                     (ej editar el body + re-validar).
               - approve / ""      → execute (o re-validate si querés otra ronda). */}}
        {{if eq .PlanVerdict "changes-requested"}}
          {{$shownIterate = true}}
          {{$bi := flowBtnState "iterate" .RunningFlow .Gates (printf "iterate #%d (aplicar findings del último validate)" .IssueNumber)}}
          <button class="btn primary"
                  hx-post="/action/iterate/{{.IssueNumber}}"
                  hx-target="#modal-slot"
                  hx-swap="innerHTML"
                  {{if $bi.Disabled}}disabled{{end}} title="{{$bi.Title}}">iterate</button>
        {{else if eq .PlanVerdict "needs-human"}}
          <span class="needs-human-hint" style="color:var(--muted); font-size: 12px; padding: 6px 0;">
            plan-validated:needs-human — resolvé a mano (editá el body del issue) antes de seguir.
          </span>
        {{else}}
          {{$shownExecute = true}}
          {{$bx := flowBtnState "execute" .RunningFlow .Gates (printf "execute #%d (plan validado → aplicar)" .IssueNumber)}}
          <button class="btn primary"
                  hx-post="/action/execute/{{.IssueNumber}}"
                  hx-target="#modal-slot"
                  hx-swap="innerHTML"
                  {{if $bx.Disabled}}disabled{{end}} title="{{$bx.Title}}">execute</button>
          {{$shownValidate = true}}
          {{$bv := flowBtnState "validate" .RunningFlow .Gates (printf "validate #%d (re-validar el plan)" .IssueNumber)}}
          <button class="btn warn"
                  hx-post="/action/validate/{{.IssueNumber}}"
                  hx-target="#modal-slot"
                  hx-swap="innerHTML"
                  {{if $bv.Disabled}}disabled{{end}} title="{{$bv.Title}}">validate</button>
        {{end}}
      {{end}}
      <a class="btn ghost" style="margin-left:auto"
         href="https://github.com/{{.NWO}}/issues/{{.IssueNumber}}"
         target="_blank" rel="noopener">ver en GH</a>
    </div>
    {{/* Reasons inline issue-only: por cada botón renderizado, si el gate lo
         bloqueó (no por RunningFlow), mostramos el motivo bajo la fila.
         Resolvemos los gates de nuevo acá (las vars del scope de arriba se
         pierden al salir del bloque). */}}
    {{$ge := gateOf "explore" .Gates}}
    {{$gx := gateOf "execute" .Gates}}
    {{$gv := gateOf "validate" .Gates}}
    {{$gi := gateOf "iterate" .Gates}}
    {{$anyBlocked := and (not .RunningFlow) (or
        (and $shownExplore  (not $ge.Available))
        (and $shownExecute  (not $gx.Available))
        (and $shownValidate (not $gv.Available))
        (and $shownIterate  (not $gi.Available)) )}}
    {{if $anyBlocked}}
    <div class="drawer-blocked-reasons">
      {{if and $shownExplore  (not $ge.Available)}}<div class="reason"><span class="flow">explore</span> ⛔ {{$ge.Reason}}</div>{{end}}
      {{if and $shownExecute  (not $gx.Available)}}<div class="reason"><span class="flow">execute</span> ⛔ {{$gx.Reason}}</div>{{end}}
      {{if and $shownValidate (not $gv.Available)}}<div class="reason"><span class="flow">validate</span> ⛔ {{$gv.Reason}}</div>{{end}}
      {{if and $shownIterate  (not $gi.Available)}}<div class="reason"><span class="flow">iterate</span> ⛔ {{$gi.Reason}}</div>{{end}}
    </div>
    {{end}}

    <div class="drawer-logs">
      <div class="drawer-logs-hdr">
        <span><b>stream</b>{{if .RunningFlow}} · claude {{displayFlow .RunningFlow}} · run {{.RunIter}}{{end}}</span>
        <div class="ctl">
          <span class="on">● auto-scroll</span>
          <span>pause</span>
          <span>clear</span>
        </div>
      </div>
      <div class="drawer-logs-body" data-entity="{{$key}}">
        {{if .LogRuns}}
          {{range .LogRuns}}
            <div class="run-sep">{{.Label}}</div>
            {{range .Entries}}
              <div>
                <span class="t">{{.Time}}</span>
                {{- if .Class}} <span class="{{.Class}}">{{.Text}}</span>{{else}} {{.Text}}{{end -}}
              </div>
            {{end}}
          {{end}}
        {{end}}
        <div class="live-log"></div>
        <div class="live-empty" style="color:var(--muted)">sin logs todavía — dispará un flow desde los botones de arriba para ver el stream en vivo.</div>
        {{if .RunningFlow}}<div class="live-cursor"><span class="cursor">&nbsp;</span></div>{{end}}
      </div>
    </div>

    {{if .IssueBody}}
      {{/* Issue-only: mostrar body abajo (no hay tabs — es la vista única). */}}
      <div class="drawer-issue-body"><div class="md">{{renderMarkdown .IssueBody}}</div></div>
    {{end}}
  {{end}}

</div>
</div>
