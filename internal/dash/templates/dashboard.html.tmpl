<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>che dash — {{.Repo}}</title>
<style>
  :root {
    --bg: #282A36;
    --panel: #21222C;
    --elevated: #1E1F29;
    --text: #F8F8F2;
    --muted: #6272A4;
    --cyan: #00D7FF;
    --magenta: #FF79C6;
    --green: #50FA7B;
    --orange: #FFB86C;
    --red: #FF5555;
    --border-muted: #44475A;
  }
  * { box-sizing: border-box; }
  html, body { height: 100%; }
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.5;
    padding: 12px;
  }

  /* ==================== Dashboard root ==================== */
  .dash {
    font-family: "JetBrains Mono","Fira Code",ui-monospace,monospace;
    background: var(--bg);
    color: var(--text);
    border-radius: 8px;
    font-size: 12px;
    height: calc(100vh - 24px);
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 12px;
    border: 1px solid var(--elevated);
    position: relative;
  }

  /* ==================== Topbar ==================== */
  .dash-top { display: flex; gap: 10px; align-items: center; }
  .dash-top .repo { color: var(--cyan); font-weight: bold; margin-right: 6px; font-size: 13px; }
  .dash-top .version {
    color: var(--muted);
    font-size: 10px;
    padding: 2px 6px;
    border: 1px solid var(--border-muted);
    border-radius: 3px;
    letter-spacing: 0.3px;
  }
  .dash-top .filter {
    background: var(--panel);
    border: 1px solid var(--elevated);
    color: var(--text);
    padding: 6px 10px;
    border-radius: 4px;
    font-family: inherit;
    font-size: 12px;
    flex: 1;
  }
  .dash-top .hint { color: var(--muted); font-size: 11px; }
  .dash-top kbd {
    background: var(--elevated);
    padding: 1px 6px;
    border-radius: 3px;
    border: 1px solid var(--border-muted);
    color: var(--text);
    font-family: inherit;
    font-size: 10px;
  }
  /* Adopt toggle (opt-in). Visual parecido al auto-loop pill para mantener
     consistencia del topbar. Off → muted; on → orange (el color de la
     columna "adopt" en el board). */
  .adopt-toggle {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 10px;
    background: var(--panel);
    border: 1px solid var(--elevated);
    border-radius: 16px;
    font-size: 11px;
    cursor: pointer;
    color: var(--text);
    font-family: inherit;
  }
  .adopt-toggle:hover { border-color: var(--border-muted); }
  .adopt-toggle input[type="checkbox"] {
    /* El input real queda oculto — el click cae sobre el <label> padre,
       que actúa como el toggle. Mantenerlo en el DOM permite que el JS
       lea .checked al reaccionar al change sin tocar estilos. */
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .adopt-toggle .switch {
    width: 28px;
    height: 14px;
    background: var(--border-muted);
    border-radius: 8px;
    position: relative;
    transition: background 0.15s;
  }
  .adopt-toggle .switch::after {
    content: "";
    position: absolute;
    top: 2px;
    left: 2px;
    width: 10px;
    height: 10px;
    background: var(--text);
    border-radius: 50%;
    transition: left 0.15s;
  }
  .adopt-toggle.on .switch { background: var(--orange); }
  .adopt-toggle.on .switch::after { left: 16px; }
  .adopt-toggle .label { color: var(--muted); }
  .adopt-toggle.on .label { color: var(--orange); }
  /* Color de cabecera de la columna "adopt" — orange para diferenciarla
     del resto. */
  .col[data-status="adopt"] .col-hdr b { color: var(--orange); }

  .auto-loop-wrap {
    position: relative;
  }
  .auto-loop-toggle {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 10px;
    background: var(--panel);
    border: 1px solid var(--elevated);
    border-radius: 16px;
    font-size: 11px;
    cursor: pointer;
    color: var(--text);
    font-family: inherit;
  }
  .auto-loop-toggle:hover { border-color: var(--border-muted); }
  .auto-loop-toggle:focus-visible { outline: 2px solid var(--cyan); outline-offset: 2px; }

  /* ==================== Loop popover ====================
     Dropdown posicionado absoluto debajo del pill. Se llena con hx-get /loop
     (lazy — el server no arma el HTML si el usuario nunca clickea). Vacío
     en el render inicial; el swap inserta .loop-popover-inner. Visible
     solo cuando hay contenido — si está vacío, el padding/border desaparece
     por el :empty selector, así no hay rectángulo fantasma en el topbar. */
  .loop-popover {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    min-width: 280px;
    background: var(--panel);
    border: 1px solid var(--elevated);
    border-radius: 6px;
    padding: 8px 10px;
    font-size: 11px;
    z-index: 500;
    box-shadow: 0 8px 24px rgba(0,0,0,0.45);
  }
  .loop-popover:empty { display: none; }
  .loop-popover-inner { display: flex; flex-direction: column; gap: 6px; }
  .loop-row { display: flex; align-items: center; gap: 8px; }
  .loop-row-label { color: var(--text); }
  .loop-row-label b { color: var(--cyan); }
  .loop-master .loop-row-label { color: var(--text); }
  /* chip code-style con la transición de estados (idea → plan, etc).
     Color cyan/azul para que destaque del label en --text y se lea como
     "metadato del flow" sin competir visualmente con la acción. */
  .loop-transition {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 10px;
    color: var(--cyan);
    background: rgba(0, 215, 255, 0.08);
    border: 1px solid rgba(0, 215, 255, 0.25);
    border-radius: 3px;
    padding: 1px 5px;
    margin-left: auto;
    white-space: nowrap;
  }
  .loop-check {
    background: transparent;
    border: 1px solid var(--border-muted);
    color: var(--muted);
    width: 22px;
    height: 22px;
    border-radius: 4px;
    font-size: 13px;
    line-height: 1;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .loop-check.on { color: var(--green); border-color: var(--green); }
  .loop-check:hover { border-color: var(--text); }
  .loop-sep {
    border: none;
    border-top: 1px solid var(--elevated);
    margin: 4px 0;
  }
  /* mini-header de cada bloque (issue/PR) — alineado a la izquierda, en
     muted+caps para que se lea como label de sección sin pesar visualmente
     contra los rows. */
  .loop-section-header {
    color: var(--muted);
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 2px 0 0 0;
  }
  .loop-foot {
    color: var(--magenta);
    font-size: 10px;
    text-align: right;
  }
  .loop-foot .count { color: var(--magenta); font-weight: bold; }
  .auto-loop-toggle .switch {
    width: 28px;
    height: 14px;
    background: var(--border-muted);
    border-radius: 8px;
    position: relative;
    transition: background 0.15s;
  }
  .auto-loop-toggle .switch::after {
    content: "";
    position: absolute;
    top: 2px;
    left: 2px;
    width: 10px;
    height: 10px;
    background: var(--text);
    border-radius: 50%;
    transition: left 0.15s;
  }
  .auto-loop-toggle.on .switch { background: var(--green); }
  .auto-loop-toggle.on .switch::after { left: 16px; }
  .auto-loop-toggle .label { color: var(--muted); }
  .auto-loop-toggle.on .label { color: var(--green); }
  .auto-loop-toggle .count {
    color: var(--magenta);
    margin-left: 2px;
    font-weight: bold;
  }

  /* ==================== Status chip (conexión al repo) ==================== */
  .status-chip {
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 10px;
    background: var(--panel);
    border: 1px solid var(--elevated);
    white-space: nowrap;
  }
  .status-chip.ok { color: var(--green); }
  .status-chip.mock { color: var(--magenta); }
  .status-chip.err { color: var(--red); }
  .status-chip.connecting { color: var(--muted); }

  /* ==================== Workspace layout ====================
     El board ocupa siempre todo el ancho; el detalle se muestra como modal
     overlay sobre el board (ver bloque "Modal" más abajo) en vez de comprimir
     la grilla con un sidebar. */
  .dash-workspace {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: 1fr;
    gap: 12px;
    min-height: 0;
  }

  /* ==================== Board ====================
     9 columnas (idea, planning, plan, executing, executed, validating,
     validated, closing, closed) reflejando los 9 estados che:* (PR2/PR3).
     Las 4 transient (planning/executing/validating/closing) se pintan en
     orange; validated en green; closed muted. min-width fuerza scroll
     horizontal en pantallas chicas — con 9 columnas el board no entra en
     viewports angostos sin que las cards queden ilegibles. */
  .dash-board {
    display: grid;
    /* Column count es dinámico: 9 default, 10 cuando el toggle "adopt" está
       ON. El template inyecta --col-count inline en el wrapper. */
    grid-template-columns: repeat(var(--col-count, 9), 1fr);
    gap: 8px;
    overflow-x: auto;
    overflow-y: hidden;
    min-width: 0;
    min-height: 0;
    /* min-width del contenido: 9 columnas con un piso razonable (~110px)
       más gaps. Si el viewport es más chico, scrolleamos en X en vez de
       comprimir las cards. */
    /* Aplicado al contenedor interno via grid items: usamos min-width: 0
       en .col + el grid template arriba; el scroll horizontal aparece en
       .dash-board cuando los grid items no entran. */
  }
  .col {
    background: var(--panel);
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    min-width: 110px;
    min-height: 0;
    overflow: hidden;
  }
  .col-hdr {
    padding: 8px 10px;
    border-bottom: 1px solid var(--elevated);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 11px;
    flex-shrink: 0;
  }
  .col-hdr b { text-transform: uppercase; letter-spacing: 0.5px; color: var(--text); }
  .col-hdr .count {
    background: var(--elevated);
    color: var(--muted);
    padding: 1px 7px;
    border-radius: 10px;
    font-size: 10px;
  }
  .col-hdr .count.hot {
    background: var(--magenta);
    color: var(--bg);
    animation: pulse 1.4s infinite;
  }
  @keyframes pulse { 50% { opacity: 0.55; } }

  /* ==================== Board loading state ====================
     Se muestra dentro de .dash-board cuando aún no hubo primer poll
     exitoso (Snapshot.LastOK.IsZero). Rompe el grid con
     grid-column: 1 / -1 para ocupar las 9 columnas y centra spinner +
     mensaje. Se reemplaza por las columnas reales en el primer
     /board exitoso (HTMX swap a 200ms del page load). */
  .board-loading {
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 60px 20px;
    color: var(--muted);
    text-align: center;
  }
  .board-loading-text {
    color: var(--text);
    font-size: 13px;
  }
  .board-loading-sub {
    color: var(--muted);
    font-size: 11px;
  }
  .board-loading code {
    background: var(--elevated);
    padding: 1px 5px;
    border-radius: 3px;
    font-family: inherit;
    font-size: 10px;
  }
  .spinner {
    width: 28px;
    height: 28px;
    border: 3px solid var(--elevated);
    border-top-color: var(--cyan);
    border-radius: 50%;
    animation: spin 0.9s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  /* Transient (los 4 *ing) en orange; validated en green; closed en muted. */
  .col[data-status="planning"] .col-hdr b,
  .col[data-status="executing"] .col-hdr b,
  .col[data-status="validating"] .col-hdr b,
  .col[data-status="closing"] .col-hdr b { color: var(--orange); }
  .col[data-status="validated"] .col-hdr b { color: var(--green); }
  .col[data-status="closed"] .col-hdr b { color: var(--muted); }

  .cards {
    padding: 6px;
    overflow: auto;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  /* ==================== Card (chips semánticos) ==================== */
  .card {
    background: var(--elevated);
    padding: 10px 12px;
    border-radius: 4px;
    cursor: pointer;
    border: 1px solid var(--elevated);
    color: var(--text);
    font-size: 12px;
    line-height: 1.4;
  }
  .card:hover { border-color: var(--border-muted); }

  .card-breadcrumb {
    color: var(--muted);
    font-size: 10px;
    margin-bottom: 4px;
    letter-spacing: 0.3px;
  }
  /* Spacing entre ref dual y breadcrumb en fused cards. */
  .card-ref + .card-breadcrumb { margin-top: 4px; }
  .card-ref {
    color: var(--cyan);
    font-size: 12px;
    font-weight: 600;
    font-family: "JetBrains Mono","Fira Code",ui-monospace,monospace;
  }
  .card-ref.issue-only { color: var(--text); }
  .card-title {
    color: var(--text);
    font-size: 12px;
    margin: 2px 0 8px;
    line-height: 1.35;
  }
  .card-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .chip {
    font-size: 10px;
    padding: 2px 6px;
    border-radius: 3px;
    background: var(--panel);
    color: var(--muted);
    letter-spacing: 0.2px;
  }
  .chip-green { background: rgba(80,250,123,0.12); color: var(--green); }
  .chip-orange { background: rgba(255,184,108,0.12); color: var(--orange); }
  .chip-red { background: rgba(255,85,85,0.14); color: var(--red); }
  .chip-magenta { background: rgba(255,121,198,0.12); color: var(--magenta); }
  .chip-cyan { background: rgba(0,215,255,0.18); color: var(--cyan); }

  /* Dual-ref line en fused cards: #issue → !pr.
     Ambos prominentes; el arrow es separador muted. */
  .card-ref .ref-issue { color: var(--text); font-weight: 600; }
  .card-ref .ref-sep   { color: var(--muted); margin: 0 4px; font-weight: 400; }
  .card-ref .ref-pr    { color: var(--cyan); font-weight: 600; }
  .chip-lock { background: rgba(255,85,85,0.18); color: var(--red); }
  .chip-cap  { background: rgba(255,184,108,0.18); color: var(--orange); cursor: help; }

  /* Breadcrumb coloreado de fused cards: each segment has its own color. */
  .card-breadcrumb .bc-from { color: var(--muted); }
  .card-breadcrumb .bc-ref  { color: var(--cyan); }
  .card-breadcrumb .bc-ct   { color: var(--cyan); }
  .card-breadcrumb .bc-type-feature { color: var(--magenta); }
  .card-breadcrumb .bc-type-fix     { color: var(--red); }
  .card-breadcrumb .bc-type-mejora  { color: var(--orange); }
  .card-breadcrumb .bc-type-ux      { color: var(--green); }
  .card-breadcrumb .bc-size { color: var(--muted); }
  .card-breadcrumb .bc-sep  { color: var(--border-muted); margin: 0 2px; }

  /* ==================== Modal ====================
     El detalle de la entidad se muestra como modal overlay sobre el board
     (no comprime la grilla). El backdrop semi-transparente cubre todo el
     viewport; el modal queda centrado y tiene 90vw × 90vh con un tope de
     1600px para no quedar gigantesco en monitores ultra wide. Cierre via
     ESC o click sobre el backdrop (ver dash.js). */
  .modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    padding: 24px;
  }
  .modal {
    width: 90vw;
    height: 90vh;
    max-width: 1600px;
    background: var(--panel);
    border-radius: 8px;
    border: 1px solid var(--elevated);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
  }

  /* ==================== Drawer ==================== */
  /* "Drawer" hoy es el contenido interno del modal — el wrapper exterior es
     .modal/.modal-backdrop pero las clases internas mantienen prefix
     `drawer-` (drawer-hdr, drawer-meta, drawer-tabs, etc.) para minimizar
     churn respecto a la versión sidebar. Puede tener tabs (fused) o ir
     directo al contenido (issue-only). */
  /* Un pane del modal ocupa todo el espacio restante y es su propio
     contenedor flex column para que el header quede fijo y los logs/body
     puedan scrollear. */
  .modal .pane {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
    overflow: hidden;
  }
  .drawer-hdr {
    padding: 12px 14px;
    border-bottom: 1px solid var(--elevated);
    background: linear-gradient(180deg, rgba(255,121,198,0.06), transparent);
  }
  .drawer-hdr-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 8px;
  }
  .drawer-close {
    background: transparent;
    border: 1px solid var(--border-muted);
    color: var(--muted);
    font-size: 14px;
    line-height: 1;
    width: 22px;
    height: 22px;
    border-radius: 3px;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
  }
  .drawer-close:hover { color: var(--text); border-color: var(--text); }
  .drawer-hdr .entity-row {
    color: var(--muted);
    font-size: 11px;
    margin-bottom: 4px;
    letter-spacing: 0.3px;
    flex: 1;
    min-width: 0;
    word-break: break-all;
  }
  .drawer-hdr .entity-row b { color: var(--cyan); }
  .drawer-hdr h3 {
    margin: 0 0 6px 0;
    font-size: 14px;
    color: var(--text);
    font-weight: normal;
  }
  .drawer-hdr .sub { color: var(--muted); font-size: 11px; }
  .drawer-hdr .drawer-chips { display: flex; gap: 4px; margin-top: 10px; flex-wrap: wrap; }

  .drawer-meta {
    padding: 10px 14px;
    border-bottom: 1px solid var(--elevated);
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 3px 10px;
    font-size: 11.5px;
    background: var(--elevated);
  }
  .drawer-meta dt { color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: 0.4px; }
  .drawer-meta dd { margin: 0; color: var(--text); }
  .drawer-meta .loop-line { color: var(--magenta); }

  .drawer-actions {
    padding: 10px 14px;
    border-bottom: 1px solid var(--elevated);
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    align-items: center;
  }
  .btn {
    background: var(--elevated);
    color: var(--text);
    border: 1px solid var(--border-muted);
    padding: 5px 10px;
    border-radius: 3px;
    font-family: inherit;
    font-size: 11px;
    cursor: pointer;
    text-decoration: none;
    transition: background 120ms ease, border-color 120ms ease, color 120ms ease, box-shadow 120ms ease, transform 80ms ease;
  }
  .btn[disabled] { opacity: 0.5; cursor: not-allowed; }
  /* Bloque de motivos de bloqueo bajo .drawer-actions: el feedback explícito
     que pidió el humano cuando un flow no se puede correr. Cada .reason es
     una línea con el nombre del flow + emoji ⛔ + Reason. Layout discreto
     pero legible (no hace falta hover sobre el botón disabled). */
  .drawer-blocked-reasons {
    padding: 6px 14px 10px;
    border-bottom: 1px solid var(--elevated);
    display: flex;
    flex-direction: column;
    gap: 3px;
    background: rgba(255,184,108,0.04);
  }
  .drawer-blocked-reasons .reason {
    font-size: 11px;
    line-height: 1.4;
    color: var(--muted);
  }
  .drawer-blocked-reasons .reason .flow {
    display: inline-block;
    min-width: 56px;
    color: var(--orange);
    font-weight: 600;
    text-transform: lowercase;
  }
  .btn.primary { background: var(--cyan); color: var(--bg); border-color: var(--cyan); }
  .btn.success { border-color: var(--green); color: var(--green); background: transparent; }
  .btn.warn { border-color: var(--orange); color: var(--orange); background: transparent; }
  .btn.danger { border-color: var(--red); color: var(--red); background: transparent; }
  .btn.ghost { border-color: var(--muted); color: var(--muted); background: transparent; }

  /* Hover / active feedback. :not([disabled]) evita feedback en el estado
     disabled (runs en curso). <a class="btn"> no tiene atributo disabled
     así que el :not() matchea y los links reciben hover normal. */
  .btn:hover:not([disabled]) { background: var(--border-muted); border-color: var(--muted); }
  .btn.primary:hover:not([disabled]) { filter: brightness(1.12); box-shadow: 0 0 0 2px rgba(0,215,255,0.25); background: var(--cyan); border-color: var(--cyan); }
  .btn.success:hover:not([disabled]) { background: rgba(80,250,123,0.12); color: var(--green); }
  .btn.warn:hover:not([disabled]) { background: rgba(255,184,108,0.14); color: var(--orange); }
  .btn.danger:hover:not([disabled]) { background: rgba(255,85,85,0.14); color: var(--red); }
  .btn.ghost:hover:not([disabled]) { color: var(--text); border-color: var(--text); background: transparent; }
  .btn:active:not([disabled]) { transform: translateY(1px); }
  .btn:focus-visible { outline: 2px solid var(--cyan); outline-offset: 2px; }

  .drawer-logs { display: flex; flex-direction: column; min-height: 0; background: #15161b; }
  .drawer-logs-hdr {
    padding: 6px 14px;
    border-bottom: 1px solid var(--elevated);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 10px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    background: var(--panel);
  }
  .drawer-logs-hdr b { color: var(--orange); }
  .drawer-logs-hdr .ctl {
    display: flex;
    gap: 8px;
    text-transform: none;
    letter-spacing: 0;
    font-size: 10px;
  }
  .drawer-logs-hdr .ctl span { cursor: pointer; }
  .drawer-logs-hdr .ctl span.on { color: var(--green); }
  .drawer-logs-body {
    flex: 1;
    padding: 10px 14px;
    overflow: auto;
    font-size: 11.5px;
    line-height: 1.55;
    color: var(--text);
  }
  .drawer-logs-body .t { color: var(--muted); }
  .drawer-logs-body .tool { color: var(--magenta); }
  .drawer-logs-body .ok { color: var(--green); }
  .drawer-logs-body .warn { color: var(--orange); }
  .drawer-logs-body .err { color: var(--red); }
  .drawer-logs-body .info { color: var(--cyan); }
  .drawer-logs-body .run-sep {
    border-top: 1px dashed var(--elevated);
    padding-top: 6px;
    margin-top: 6px;
    color: var(--muted);
    font-size: 10px;
  }
  .cursor {
    display: inline-block;
    width: 7px;
    background: var(--text);
    animation: blink 1s step-end infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }

  /* ==================== Refs clickables (cards + drawer) ====================
     Los <a> dentro de .card-ref y .entity-row heredan el color del contenedor
     (las clases ref-issue/ref-pr ya llevan color explícito, así que
     `color: inherit` preserva ese tono). Subrayado solo al hover para no
     competir visualmente con las columnas. */
  .card-ref a, .entity-row a {
    color: inherit;
    text-decoration: none;
    cursor: pointer;
  }
  .card-ref a:hover, .entity-row a:hover {
    text-decoration: underline;
  }

  /* ==================== Drawer tabs (fused: PR | Issue) ====================
     El toggle es via atributo data-tab en .modal (pr|issue). Sin JS activo
     el modal arranca en "pr" (default en el template) — los selectores de
     abajo ocultan el pane que no corresponde. Las clases internas siguen
     con prefix drawer-* para no churnear el resto del CSS. */
  .drawer-tabs {
    display: flex;
    gap: 4px;
    padding: 12px 16px 0;
    border-bottom: 1px solid var(--elevated);
    flex-shrink: 0;
  }
  .drawer-tabs .tab {
    background: transparent;
    border: none;
    color: var(--muted);
    font: inherit;
    padding: 8px 14px;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
  }
  .drawer-tabs .tab:hover { color: var(--text); }
  .modal[data-tab="pr"] .tab-pr,
  .modal[data-tab="issue"] .tab-issue {
    color: var(--cyan);
    border-bottom-color: var(--cyan);
  }
  .modal[data-tab="pr"] .pane-issue { display: none; }
  .modal[data-tab="issue"] .pane-pr { display: none; }

  /* Cuerpo del tab Issue (y body al pie del issue-only). Scroll interno
     para que el body largo no rompa el alto del drawer. */
  .drawer-issue-body {
    padding: 12px 16px;
    overflow: auto;
    flex: 1;
    min-height: 0;
  }
  .drawer-issue-body pre {
    margin: 0;
    white-space: pre-wrap;
    word-wrap: break-word;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 12px;
    line-height: 1.5;
    color: var(--text);
  }

  /* ==================== Markdown rendering (.md) ====================
     GFM del body del issue renderizado por goldmark. Paleta Dracula;
     code spans y fences en --elevated; tipografía sans-serif para texto
     corrido y mono solo en code/pre. */
  .md {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 13px;
    line-height: 1.6;
    color: var(--text);
  }
  .md h1, .md h2, .md h3, .md h4, .md h5, .md h6 {
    color: var(--text);
    margin: 18px 0 8px;
    line-height: 1.3;
  }
  .md h1 { font-size: 20px; border-bottom: 1px solid var(--elevated); padding-bottom: 6px; }
  .md h2 { font-size: 17px; border-bottom: 1px solid var(--elevated); padding-bottom: 4px; }
  .md h3 { font-size: 15px; }
  .md h4, .md h5, .md h6 { font-size: 13px; color: var(--muted); }
  .md p { margin: 8px 0; }
  .md a { color: var(--cyan); text-decoration: none; }
  .md a:hover { text-decoration: underline; }
  .md ul, .md ol { margin: 8px 0; padding-left: 24px; }
  .md li { margin: 3px 0; }
  .md li > p { margin: 2px 0; }
  .md strong, .md b { color: var(--text); font-weight: 600; }
  .md em, .md i { color: var(--text); }
  .md code {
    font-family: "JetBrains Mono","Fira Code",ui-monospace,monospace;
    background: var(--elevated);
    color: var(--magenta);
    padding: 1px 5px;
    border-radius: 3px;
    font-size: 12px;
  }
  .md pre {
    background: var(--elevated);
    border: 1px solid var(--border-muted);
    border-radius: 4px;
    padding: 10px 12px;
    overflow-x: auto;
    margin: 10px 0;
  }
  .md pre code {
    background: transparent;
    color: var(--text);
    padding: 0;
    font-size: 12px;
  }
  .md blockquote {
    border-left: 3px solid var(--border-muted);
    margin: 10px 0;
    padding: 2px 12px;
    color: var(--muted);
  }
  .md hr {
    border: none;
    border-top: 1px solid var(--elevated);
    margin: 16px 0;
  }
  .md table {
    border-collapse: collapse;
    margin: 10px 0;
    font-size: 12px;
  }
  .md th, .md td {
    border: 1px solid var(--elevated);
    padding: 6px 10px;
    text-align: left;
  }
  .md th { background: var(--elevated); color: var(--text); font-weight: 600; }
  .md img { max-width: 100%; border-radius: 4px; }
  .md input[type="checkbox"] { margin-right: 6px; }
  .md del { color: var(--muted); }
</style>
</head>
<body>

<div class="dash">

  <!-- Topbar -->
  <div class="dash-top">
    <span class="repo">{{.Repo}}</span>
    {{if .Version}}<span class="version" title="versión del binario che que está sirviendo este dash">{{.Version}}</span>{{end}}
    <input class="filter" placeholder="filter: type:feature, author:@me, label:urgent" value="">
    {{/* Adopt toggle (opt-in). On → muestra la columna "adopt" con PRs
         untracked. Persistencia en localStorage (ver dash.js): recarga de
         página respeta el estado. */}}
    <label class="adopt-toggle{{if .Adopt}} on{{end}}" title="muestra la columna 'adopt' con PRs que no están linkeados a issues trackeados por che">
      <input type="checkbox" id="adopt-toggle-input"{{if .Adopt}} checked{{end}}>
      <span class="switch"></span>
      <span class="label">show untracked PRs</span>
    </label>
    <div class="auto-loop-wrap">
      {{template "auto-loop-toggle" .Loop}}
      <div id="loop-popover" class="loop-popover" aria-hidden="true"></div>
    </div>
    {{template "status-chip" .}}
    <span class="hint"><kbd>/</kbd> buscar · <kbd>Esc</kbd> cerrar</span>
  </div>

  <div class="dash-workspace">

    <!-- ==== BOARD ==== -->
    {{/* Primer render: el wrapper se swappea por outerHTML en el primer poll
         (ver board-partial). El trigger "load delay:200ms" fuerza ese poll a
         dispararse 200ms después de cargar la página (sin esperar al tick
         baseline de NextPollSec). A partir de ahí el partial rige su propio
         hx-trigger — el load no vuelve a correr porque el elemento nuevo
         (con id=dash-board del partial) tiene solo "every NextPollSec s".
         El polling es adaptivo: idle → PollInterval, hot (hay flows locales
         en curso) → hotPollSec. Ver buildData.NextPollSec.
         --col-count: adopt OFF → 9 columnas, adopt ON → 10. */}}
    <div id="dash-board" class="dash-board"
         style="--col-count: {{if .Adopt}}10{{else}}9{{end}};"
         hx-get="/board{{if .Adopt}}?adopt=1{{end}}"
         hx-trigger="load delay:200ms, every {{.NextPollSec}}s"
         hx-swap="outerHTML">
      {{template "board-columns" .}}
    </div>

    <!-- ==== MODAL slot (vacío al cargar; htmx lo llena al clickear una card) ==== -->
    {{/* El slot vive dentro del workspace por simplicidad, pero el modal
         renderizado adentro tiene `position: fixed`, así que se posiciona
         relativo al viewport (no al workspace). El slot vacío no ocupa
         espacio porque su contenido es nada hasta que entra el partial. */}}
    <div id="modal-slot"></div>

  </div>
</div>

<script src="/static/htmx.min.js"></script>
<script src="/static/dash.js"></script>

</body>
</html>
